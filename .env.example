# ── Members area (server-only secrets — never exposed to the browser) ──
# Passphrase members type to view the gate PIN codes
MEMBERS_PASSPHRASE=growtogether
# Separate passphrase for the /admin page that edits the gate codes
ADMIN_PASSPHRASE=change-me-to-an-admin-passphrase
# Long random string used to sign the member/admin cookies. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# Gate PIN codes — SEED DEFAULTS only. Once edited via /admin they are stored
# in DATA_DIR and take priority over these. Only sent to the browser AFTER a
# correct passphrase.
GATE_CODE=1303
ALLOTMENT_GATE_CODE=3254

# Where admin-edited settings are written. In Docker this is the mounted
# volume (/data); locally it defaults to ./data if unset.
DATA_DIR=./data

# ── Waiting-list form ──
# Formspree form id (the bit after /f/ in your endpoint). Build-time value —
# must be set at BUILD time on every platform (Docker build arg, or the
# environment of `npm run cf:build`), since NEXT_PUBLIC_* is inlined.
NEXT_PUBLIC_FORMSPREE_ID=YOUR_FORMSPREE_ID

# ── Cloudflare ──
# Hosting is dual-target: Docker/Pi uses the DATA_DIR file store above;
# Cloudflare Workers uses the CYD_KV namespace (see wrangler.jsonc). The same
# code auto-detects which backend it's on. On Cloudflare set the secrets with
# `wrangler secret put MEMBERS_PASSPHRASE` (and ADMIN_PASSPHRASE, AUTH_SECRET).
# For local `wrangler` preview, copy .dev.vars.example -> .dev.vars instead.
